APP_ENV=production
APP_PORT=8080
PUBLIC_BASE_URL=https://orchidmart.example.com
CORS_ALLOWED_ORIGINS=https://orchidmart.example.com
FRONTEND_URL=https://orchidmart.example.com

DB_USER=orchidmart
DB_PASSWORD=change-this-database-password
DB_NAME=orchidmart
DB_PORT=5432

REDIS_PORT=6379

JWT_SECRET=change-this-long-random-secret-at-least-32-chars
ADMIN_EMAIL=admin@orchidmart.example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=OrchidMart Admin

MIDTRANS_SERVER_KEY=change-this-midtrans-server-key
MIDTRANS_CLIENT_KEY=change-this-midtrans-client-key
MIDTRANS_IS_PRODUCTION=true
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=change-this-midtrans-client-key

RAJAONGKIR_API_KEY=change-this-rajaongkir-key

STORAGE_DRIVER=s3
S3_ACCESS_KEY=change-this-minio-access-key
S3_SECRET_KEY=change-this-minio-secret-key-min-8-chars
S3_BUCKET=orchidmart-images
S3_USE_SSL=false
S3_PUBLIC_URL=https://orchidmart.example.com/media/orchidmart-images

UPLOAD_PUBLIC_URL=https://orchidmart.example.com/uploads

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=change-this-smtp-password
SMTP_FROM=noreply@orchidmart.example.com

NEXT_PUBLIC_API_URL=https://orchidmart.example.com/api/v1
